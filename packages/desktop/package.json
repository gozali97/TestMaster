{
  "name": "@testmaster/desktop",
  "version": "1.0.0",
  "description": "TestMaster Desktop IDE - AI-augmented test automation with bundled Playwright",
  "author": "TestMaster <support@testmaster.local>",
  "homepage": "https://testmaster.local",
  "main": "./dist/main/index.js",
  "scripts": {
    "build": "npm run bundle-browsers && npm run build:main && npm run build:renderer && electron-builder",
    "bundle-browsers": "node scripts/bundle-browsers.js",
    "build:main": "tsc -b tsconfig.main.json --force",
    "build:renderer": "vite build",
    "make-icon": "node scripts/make-icon.js",
    "dist:prepare": "npm run make-icon && npm run bundle-browsers && npm run build:main && npm run build:renderer",
    "dist:linux": "npm run dist:prepare && electron-builder --linux deb",
    "dist:win": "npm run dist:prepare && electron-builder --win nsis",
    "dist:all": "npm run dist:prepare && electron-builder --linux deb --win nsis",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5175 && electron .",
    "kill-port": "pwsh -File kill-port.ps1 -Port 5175",
    "clean": "pwsh -Command \"Remove-Item -Recurse -Force dist,dist-electron,node_modules/.vite -ErrorAction SilentlyContinue\"",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@testmaster/shared": "*",
    "@testmaster/test-engine": "*",
    "axios": "^1.6.2",
    "lucide-react": "^0.303.0",
    "monaco-editor": "^0.45.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^24.9.1",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "playwright": "^1.56.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.testmaster.app",
    "productName": "TestMaster",
    "executableName": "testmaster",
    "electronVersion": "28.3.3",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "ms-playwright",
        "to": "ms-playwright",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Development",
      "maintainer": "TestMaster <support@testmaster.local>",
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
